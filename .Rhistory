# Chunk 7
# n/pct
design <- ccl %>%
select(school_id, starts_with("ccl_design")) %>%
pivot_longer(cols = -school_id,
names_to = "variable",
values_to = "selection") %>%
left_join(labs, by = "variable") %>%
group_by(short_label) %>%
summarize(n = sum(selection),
total = n_distinct(school_id),
pct = n/total)
# create plot
design_plot <-
design %>%
ggplot(., aes(pct, reorder(short_label, pct))) +
geom_col(fill = "#004B72") +
scale_x_continuous(expand = c(0,0),
limits = c(0, 1.05),
labels = scales::label_percent()) +
scale_y_discrete(labels = function(x) stringr::str_wrap(x, width = 45)) +
theme_bw() +
labs(x = "Percent of CCL schools",
y = "") +
theme(axis.text = element_text(size = 12),
panel.grid.major.y = element_blank(),
panel.grid.minor.y = element_blank(),
panel.grid.minor.x = element_blank()) +
geom_text(aes(label = scales::number(pct * 100, accuracy = 1)),
hjust = -.1,
color = "black",
size = 5)
design_plot
# Chunk 9
ccl %>%
select(school_id, grades_elementary, grades_middle, grades_high) %>%
pivot_longer(cols = -school_id,
names_to = "grade_level",
values_to = "n") %>%
group_by(grade_level) %>%
summarize(n = sum(n), .groups = "drop") %>%
mutate(grade_level = factor(grade_level,
levels = c("grades_elementary", "grades_middle", "grades_high"),
labels = c("Elementary", "Middle", "High"))) %>%
ggplot(., aes(grade_level, n)) +
geom_col(fill = "#004B72") +
scale_y_continuous(expand = c(0,0),
limits = c(0, 80)) +
theme_bw() +
labs(y = "N of CCL schools",
x = "") +
theme(axis.text = element_text(size = 12),
panel.grid.major.x = element_blank()) +
geom_text(aes(label = n),
vjust = -.5,
color = "black",
size = 5)
# Chunk 10
# n/pct
design_grade <- ccl %>%
select(school_id, starts_with("ccl_design"), grades_elementary, grades_middle, grades_high) %>%
pivot_longer(cols = starts_with("ccl_design"),
names_to = "variable",
values_to = "selection") %>%
pivot_longer(cols = starts_with("grades_"),
names_to = "grade_level",
values_to = "grade_selected",
names_prefix = "grades_") %>%
filter(selection == 1, grade_selected == 1) %>%
left_join(labs, by = "variable") %>%
group_by(short_label, grade_level) %>%
summarize(n = n_distinct(school_id), .groups = "drop") %>%
mutate(total = case_when(
grade_level == "elementary" ~ 30,
grade_level == "middle" ~ 41,
grade_level == "high" ~ 71
),
pct = n/total,
grade_level = factor(grade_level,
levels = c("elementary", "middle", "high"),
labels = c("Elementary", "Middle", "High")))
# create plot
design_grade_plot <-
design_grade %>%
ggplot(., aes(pct, reorder(short_label, pct))) +
geom_col(fill = "#004B72") +
scale_x_continuous(expand = c(0,0),
limits = c(0, 1.05),
labels = scales::label_percent()) +
scale_y_discrete(labels = function(x) stringr::str_wrap(x, width = 30)) +
theme_bw() +
labs(x = "Percent of CCL schools",
y = "") +
theme(axis.text.x = element_text(size = 9),
axis.text.y = element_text(size = 12),
panel.grid.major.y = element_blank(),
panel.grid.minor.y = element_blank(),
panel.grid.minor.x = element_blank()) +
geom_text(aes(label = scales::number(pct * 100, accuracy = 1)),
hjust = -.1,
color = "black",
size = 4) +
facet_wrap(~grade_level)
design_grade_plot
# Chunk 12
# Clean up
rm(design, design_plot, design_grade, design_grade_plot)
# n/pct of goals
ccl_outcomes <- ccl %>%
select(school_id, starts_with("ccl_outcome")) %>%
select(-ends_with("measure")) %>%
pivot_longer(cols = -school_id,
names_to = "variable",
values_to = "selection") %>%
mutate(rate = 1) %>%
left_join(labs, by = "variable") %>%
filter(!is.na(selection)) %>%
group_by(short_label, selection) %>%
summarize(n = sum(rate), .groups = "drop") %>%
group_by(short_label) %>%
mutate(total = sum(n),
pct = n/total) %>%
mutate(selection = factor(selection, levels = c("Not important", "Somewhat not important", "Somewhat important", "Very important")))
# create plot
ccl_outcomes_plot <-
ccl_outcomes %>%
ggplot(., aes(pct, reorder(short_label, pct), fill = selection)) +
geom_bar(position = "stack", stat = "identity") +
scale_fill_manual(values = c("#F2AD4B", "#F9DAAF", "#0178BA", "#004B72")) +
scale_x_continuous(expand = c(0,0),
limits = c(0, 1),
labels = scales::label_percent()) +
scale_y_discrete(labels = function(x) stringr::str_wrap(x, width = 30)) +
theme_bw() +
labs(x = "Percent of CCL schools",
y = "",
fill = "") +
theme(axis.text = element_text(size = 11),
panel.grid.major.y = element_blank(),
panel.grid.minor.y = element_blank(),
legend.position = "top",
legend.text = element_text(size = 8)) +
guides(fill = guide_legend(reverse = TRUE))
ccl_outcomes_plot
# Save
write.csv(ccl_outcomes, "output/ccl_preview/data/ccl_outcomes.csv", row.names = FALSE)
ggsave("output/ccl_preview/plots/ccl_outcomes.png", plot = ccl_outcomes_plot, width = 8, height = 6, dpi = 300)
