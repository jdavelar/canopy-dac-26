# n/pct of goals
ccl_outcomes_hs <- ccl %>%
select(school_id, starts_with("ccl_outcome"), grades_high) %>%
select(-ends_with("measure")) %>%
pivot_longer(
cols = -c(school_id, grades_high),
names_to = "variable",
values_to = "selection"
) %>%
mutate(
selection = case_when(
selection %in% c("Very important", "Somewhat important") ~ "Important",
selection %in% c("Somewhat not important", "Not important") ~ "Not important",
TRUE ~ NA_character_
),
grades_high = case_when(
grades_high == 1 ~ "High school",
grades_high == 0 ~ "Not high school",
TRUE ~ NA_character_
)
) %>%
left_join(labs, by = "variable") %>%
filter(!is.na(selection), !is.na(grades_high)) %>%
group_by(short_label, grades_high, selection) %>%
summarize(n = n(), .groups = "drop") %>%
group_by(short_label, grades_high) %>%
mutate(
total = sum(n),
pct = n / total,
selection = factor(selection, levels = c("Not important", "Important"))
) %>%
ungroup()
