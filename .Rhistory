str_trim(unlist(str_split(noms_2025, ",| and "))),
noms_2026
) |> unique()
case_when(
length(all_noms) == 1 ~ all_noms[1],
length(all_noms) == 2 ~ paste(all_noms, collapse = " and "),
TRUE ~ paste0(
paste(all_noms[-length(all_noms)], collapse = ", "),
", and ",
all_noms[length(all_noms)]
)
)
}
)
) %>%
ungroup() %>%
select(-noms_2025, -noms_2026)
